# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

.vercel

# TypeScript incremental build info
*.tsbuildinfo

# Avoid mixed lockfiles (we use Yarn)
package-lock.json

# Env files
.env
.env.*
!.env.example

# Local-only Copilot/assistant session notes (do not commit)
notes/_copilot/*

# Temporary backup for images detected as unused during cleanups
src/assets/_unused_images_backup-*/

# Temporary TS/diagnostics output (local only)
tsc.out.txt
tsc.err.txt
